---
import Badge from "../../components/Badge.astro";
import Button from "../../components/Button.astro";
import Card from "../../components/Card.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import { getCarById } from "../../data/cars";
import { formatDateTime, isCarAvailableMock, isDateRangeValid, parseDate } from "../../lib/booking-flow";
import BaseLayout from "../../layouts/BaseLayout.astro";

const carId = Astro.params.id ?? "";
const car = getCarById(carId);

if (!car) {
  return Astro.redirect("/search");
}

const params = Astro.url.searchParams;
const pickup = params.get("pickup") ?? "";
const dropoff = params.get("dropoff") ?? "";
const location = params.get("location") ?? "";

const pickupDate = parseDate(pickup);
const dropoffDate = parseDate(dropoff);
const hasValidDates = isDateRangeValid(pickupDate, dropoffDate);
const available = pickupDate && dropoffDate && hasValidDates ? isCarAvailableMock(car.id, pickupDate, dropoffDate) : false;

const bookingParams = new URLSearchParams();
bookingParams.set("carId", car.id);
if (pickup) bookingParams.set("pickup", pickup);
if (dropoff) bookingParams.set("dropoff", dropoff);
if (location) bookingParams.set("location", location);
const continueHref = `/booking?${bookingParams.toString()}`;
---

<BaseLayout title={`${car.name} | ChaoLoey`}>
  <Navbar currentPath="/search" />

  <main class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6">
    <a href={`/search?${new URLSearchParams({ location, pickup, dropoff }).toString()}`} class="text-sm text-[rgba(249,250,251,0.70)] hover:text-[#F9FAFB]">
      &larr; Back to results
    </a>

    <section class="mt-4 grid gap-6 lg:grid-cols-[1.15fr_1fr]">
      <Card class="p-5">
        <img src={car.image} alt={car.name} class="h-[340px] w-full rounded-2xl border border-white/10 object-cover" />
        <div class="mt-3 grid grid-cols-3 gap-3">
          <div class="h-20 rounded-2xl border border-white/10 bg-gradient-to-br from-[#F59E0B]/20 to-transparent"></div>
          <div class="h-20 rounded-2xl border border-white/10 bg-gradient-to-br from-[#F59E0B]/20 to-transparent"></div>
          <div class="h-20 rounded-2xl border border-white/10 bg-gradient-to-br from-[#F59E0B]/20 to-transparent"></div>
        </div>
      </Card>

      <Card class="p-6">
        <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">{car.brand} &middot; {car.type}</p>
        <h1 class="mt-2 text-3xl font-black">{car.name}</h1>
        <p class="mt-3 text-sm text-[rgba(249,250,251,0.70)]">
          <span class="text-3xl font-black text-[#F59E0B]">{car.pricePerDay.toLocaleString()}</span> THB / day
        </p>

        <div class="mt-4 flex flex-wrap gap-2">
          <Badge>{car.seats} seats</Badge>
          <Badge>{car.gear}</Badge>
          <Badge>{car.fuel}</Badge>
          <Badge variant="warning">&starf; {car.rating.toFixed(1)}</Badge>
        </div>

        <div class="mt-6 rounded-2xl border border-white/10 bg-[#111827] p-4">
          <h2 class="font-semibold">Selected schedule</h2>
          {pickupDate && dropoffDate && hasValidDates ? (
            <p class="mt-2 text-sm text-[rgba(249,250,251,0.75)]">
              {formatDateTime(pickupDate)} to {formatDateTime(dropoffDate)}
            </p>
          ) : (
            <p class="mt-2 text-sm text-[#EF4444]">Pickup and drop-off date/time are missing or invalid.</p>
          )}
          <p class="mt-2 text-sm text-[rgba(249,250,251,0.75)]">Location: {location || "-"}</p>
        </div>

        <div class="mt-4">
          {hasValidDates ? (
            available ? <Badge variant="success">Available for selected dates</Badge> : <Badge variant="danger">Unavailable for selected dates</Badge>
          ) : (
            <Badge variant="danger">Invalid date range</Badge>
          )}
        </div>

        <div class="mt-6">
          {hasValidDates && available ? (
            <Button href={continueHref} variant="primary" class="px-6 py-3">Continue booking</Button>
          ) : (
            <Button href="/search" variant="outline" class="px-6 py-3">Back to search</Button>
          )}
        </div>
      </Card>
    </section>
  </main>

  <Footer />
</BaseLayout>
