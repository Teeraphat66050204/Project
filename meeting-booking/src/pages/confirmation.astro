---
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const bookingId = Astro.url.searchParams.get("bookingId") ?? "";
---

<BaseLayout title="Confirmation | ChaoLoey">
  <Navbar currentPath="/account" />

  <main class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6">
    <h1 class="text-3xl font-black">Booking confirmation</h1>
    <p class="mt-2 text-sm text-[rgba(249,250,251,0.70)]">Reference ID: {bookingId || "-"}</p>

    <div id="missing" class:list={["status-banner mt-5", bookingId ? "hidden" : ""]}>
      Missing booking reference.
    </div>

    <div id="content" class:list={["mt-5 grid gap-6 lg:grid-cols-[1fr_280px]", !bookingId && "hidden"]}>
      <Card class="p-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Booking ID</p>
            <p id="bk-id" class="text-lg font-bold">-</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Status</p>
            <p><Badge id="bk-status" variant="warning">pending</Badge></p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Car</p>
            <p id="bk-car" class="font-semibold">-</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Transaction</p>
            <p id="bk-tx" class="font-semibold">-</p>
          </div>
          <div class="sm:col-span-2">
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Pickup - Dropoff</p>
            <p id="bk-date" class="text-sm">-</p>
          </div>
          <div class="sm:col-span-2">
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Location</p>
            <p id="bk-location" class="text-sm">-</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[rgba(249,250,251,0.70)]">Total</p>
            <p id="bk-total" class="text-xl font-black text-[#F59E0B]">-</p>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={`/account?focus=${encodeURIComponent(bookingId)}`} variant="outline" class="px-5 py-3">View booking</Button>
          <Button href="/" variant="primary" class="px-5 py-3">Back to home</Button>
        </div>
      </Card>

      <Card class="p-6 text-center">
        <p class="font-semibold">QR Placeholder</p>
        <div class="mx-auto mt-4 flex h-[220px] w-[220px] items-center justify-center rounded-2xl border border-white/10 bg-[#111827]">
          <p id="qr-text" class="text-xs text-[rgba(249,250,251,0.70)]">QR for booking</p>
        </div>
      </Card>
    </div>
  </main>

  <Footer />

  <script define:vars={{ bookingId }}>
    const content = document.querySelector("#content");
    const missing = document.querySelector("#missing");

    const setMissing = (message) => {
      content?.classList.add("hidden");
      missing.classList.remove("hidden");
      missing.textContent = message;
    };

    const fillFromApi = (payload) => {
      const booking = payload.booking;
      const confirmation = payload.confirmation;
      document.querySelector("#bk-id").textContent = booking.id;
      document.querySelector("#bk-car").textContent = booking.car?.name || "-";
      document.querySelector("#bk-tx").textContent = confirmation.transactionId || "Pending transaction";
      document.querySelector("#bk-date").textContent = `${new Date(booking.startTime).toLocaleString()} - ${new Date(booking.endTime).toLocaleString()}`;
      document.querySelector("#bk-location").textContent = confirmation.pickupLocation || "-";
      document.querySelector("#bk-total").textContent = `${Number(confirmation.amount || 0).toLocaleString()} THB`;
      document.querySelector("#bk-status").textContent = String(booking.status || "pending").toLowerCase();
      document.querySelector("#qr-text").textContent = booking.id;
    };

    const fillFromSessionFallback = () => {
      const key = bookingId ? `chaoloey_booking_${bookingId}` : "";
      const raw = key ? sessionStorage.getItem(key) : null;
      const data = raw ? JSON.parse(raw) : null;
      if (!data) {
        setMissing("Booking details not found for this account.");
        return;
      }
      document.querySelector("#bk-id").textContent = data.id;
      document.querySelector("#bk-car").textContent = data.carName;
      document.querySelector("#bk-tx").textContent = data.transactionId || "Pending transaction";
      document.querySelector("#bk-date").textContent = `${new Date(data.pickup).toLocaleString()} - ${new Date(data.dropoff).toLocaleString()}`;
      document.querySelector("#bk-location").textContent = data.location || "-";
      document.querySelector("#bk-total").textContent = `${data.pricing.total.toLocaleString()} THB`;
      document.querySelector("#bk-status").textContent = data.status ?? "pending";
      document.querySelector("#qr-text").textContent = data.id;
    };

    if (bookingId) {
      fetch(`/api/checkout/confirmation/${encodeURIComponent(bookingId)}`, {
        method: "GET",
        credentials: "include",
      })
        .then(async (res) => {
          if (!res.ok) throw new Error("NOT_FOUND");
          const body = await res.json();
          if (!body?.ok || !body?.data) throw new Error("NOT_FOUND");
          fillFromApi(body.data);
        })
        .catch(() => {
          fillFromSessionFallback();
        });
    }
  </script>
</BaseLayout>
