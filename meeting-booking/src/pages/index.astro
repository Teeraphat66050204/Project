---
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import CarCard from "../components/CarCard.astro";
import DateTimeInput from "../components/DateTimeInput.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Select from "../components/Select.astro";
import { cars } from "../data/cars";
import BaseLayout from "../layouts/BaseLayout.astro";

const popularCars = cars.slice(0, 6);
const brandLogos = [
  { name: "HONDA", src: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/honda.svg" },
  { name: "JAGUAR", src: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/jaguar.svg" },
  { name: "NISSAN", src: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/nissan.svg" },
  { name: "VOLVO", src: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/volvo.svg" },
  { name: "AUDI", src: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/audi.svg" },
  { name: "ACURA", src: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/acura.svg" },
];
---

<BaseLayout title="ChaoLoey | Premium Car Rental">
  <Navbar currentPath="/" />

  <main id="main-content">
    <section class="mx-auto grid w-full max-w-7xl gap-8 px-4 pb-10 pt-10 sm:px-6 lg:grid-cols-2 lg:items-center lg:pt-14">
      <div>
        <Badge variant="warning">Dark Premium Rental</Badge>
        <h1 class="mt-5 text-4xl font-black leading-tight text-[#F9FAFB] sm:text-5xl">
          Find, book and rent a car with confidence
        </h1>
        <p class="mt-4 max-w-xl text-base text-[rgba(249,250,251,0.70)] sm:text-lg">
          ChaoLoey helps you discover premium cars at transparent prices. Reserve in minutes and drive with a smooth, secure experience.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <Button href="#search-form" variant="primary" class="px-6 py-3">Start searching</Button>
          <Button href="/search" variant="outline" class="px-6 py-3">Browse all cars</Button>
        </div>
      </div>

      <Card class="relative overflow-hidden p-6">
        <div class="absolute inset-0 bg-gradient-to-br from-[#F59E0B]/20 via-transparent to-[#EF4444]/20"></div>
        <div class="relative h-[320px] overflow-hidden rounded-2xl border border-white/10 bg-[#111827]">
          <video
            class="h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            aria-label="Featured BMW M4 cinematic video"
          >
            <source src="/media/hero-bmw-m4.mp4" type="video/mp4" />
          </video>
          <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#111827]/85 to-transparent"></div>
        </div>
      </Card>
    </section>

    <section id="search-form" class="mx-auto w-full max-w-7xl px-4 pb-4 sm:px-6">
      <Card class="p-5 sm:p-6">
        <form id="landing-search-form" action="/search" method="GET" class="grid gap-4 lg:grid-cols-[1.1fr_1fr_1fr_auto]" novalidate>
          <Select
            id="location"
            name="location"
            label="Location"
            required
            options={[
              { label: "Select city", value: "" },
              { label: "Bangkok", value: "Bangkok" },
              { label: "Chiang Mai", value: "Chiang Mai" },
              { label: "Phuket", value: "Phuket" },
              { label: "Pattaya", value: "Pattaya" },
            ]}
          />
          <DateTimeInput id="pickup" name="pickup" label="Pick-up date & time" required />
          <DateTimeInput id="dropoff" name="dropoff" label="Drop-off date & time" required />
          <div class="flex items-end">
            <Button type="submit" variant="primary" fullWidth class="px-5 py-3">Search</Button>
          </div>
          <p id="search-error" class="status-banner hidden lg:col-span-4" role="alert"></p>
          <p id="search-loading" class="info-banner hidden lg:col-span-4" aria-live="polite">Searching available cars...</p>
        </form>
      </Card>
    </section>

    <section class="mx-auto w-full max-w-7xl px-4 pb-4 pt-10 sm:px-6">
      <div class="text-center">
        <Badge variant="warning">How it works</Badge>
        <h2 class="mt-3 text-3xl font-black">Rent with 3 quick steps</h2>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <Card as="article" class="p-6">
          <p class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#F59E0B] font-bold text-[#111827]">1</p>
          <h3 class="mt-4 text-xl font-bold">Choose location</h3>
          <p class="mt-2 text-sm text-[rgba(249,250,251,0.70)]">Pick your city and where you want to receive the car.</p>
        </Card>
        <Card as="article" class="p-6">
          <p class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#F59E0B] font-bold text-[#111827]">2</p>
          <h3 class="mt-4 text-xl font-bold">Select date & time</h3>
          <p class="mt-2 text-sm text-[rgba(249,250,251,0.70)]">Set pickup and drop-off schedule that fits your plan.</p>
        </Card>
        <Card as="article" class="p-6">
          <p class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#F59E0B] font-bold text-[#111827]">3</p>
          <h3 class="mt-4 text-xl font-bold">Confirm booking</h3>
          <p class="mt-2 text-sm text-[rgba(249,250,251,0.70)]">Complete booking details and proceed to secure payment.</p>
        </Card>
      </div>
    </section>

    <section class="mx-auto w-full max-w-7xl px-4 pb-4 pt-8 sm:px-6">
      <h2 class="sr-only">Brands</h2>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {brandLogos.map((brand) => (
          <Card class="relative flex items-end justify-center overflow-hidden py-4">
            <img
              src={brand.src}
              alt=""
              aria-hidden="true"
              class="pointer-events-none absolute left-1/2 top-1/2 h-12 w-12 -translate-x-1/2 -translate-y-1/2 opacity-20 [filter:brightness(0)_invert(1)]"
              loading="lazy"
            />
            <p class="relative z-10 text-base font-black tracking-[0.24em] text-[rgba(249,250,251,0.60)]">{brand.name}</p>
          </Card>
        ))}
      </div>
    </section>

    <section class="mx-auto w-full max-w-7xl px-4 pb-4 pt-10 sm:px-6">
      <div class="flex items-end justify-between gap-4">
        <div>
          <Badge variant="warning">Popular cars</Badge>
          <h2 class="mt-3 text-3xl font-black">Most popular rental deals</h2>
        </div>
      </div>
      <div class="mt-7 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {popularCars.map((car) => (
          <CarCard car={car} />
        ))}
      </div>
    </section>

    <section class="mx-auto w-full max-w-7xl px-4 pb-16 pt-10 sm:px-6">
      <div class="text-center">
        <Badge variant="warning">Testimonials</Badge>
        <h2 class="mt-3 text-3xl font-black">What customers say</h2>
      </div>
      <div class="mt-7 grid gap-4 md:grid-cols-3">
        {[
          { name: "Charlie Johnson", rating: "5.0", text: "Reservation was quick and the car arrived spotless. Great premium service." },
          { name: "Emily Wilson", rating: "4.8", text: "Pricing is clear and the booking process is very smooth from start to finish." },
          { name: "David Lee", rating: "4.9", text: "Excellent support and excellent car condition. Will definitely rent again." },
        ].map((item) => (
          <Card as="article" class="p-6">
            <Badge variant="warning" class="gap-2"><span>&starf;</span> {item.rating}</Badge>
            <p class="mt-4 text-sm text-[rgba(249,250,251,0.78)]">{item.text}</p>
            <p class="mt-4 font-semibold">{item.name}</p>
          </Card>
        ))}
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const form = document.querySelector("#landing-search-form");
    const pickupInput = document.querySelector("#pickup");
    const dropoffInput = document.querySelector("#dropoff");
    const locationInput = document.querySelector("#location");
    const errorEl = document.querySelector("#search-error");
    const loadingEl = document.querySelector("#search-loading");
    const submitBtn = form?.querySelector("button[type='submit']");

    const toLocalInputValue = (date) => {
      const pad = (n) => String(n).padStart(2, "0");
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
    };

    const roundUpToNextHour = (date) => {
      const rounded = new Date(date);
      const hasFraction = rounded.getMinutes() > 0 || rounded.getSeconds() > 0 || rounded.getMilliseconds() > 0;
      if (hasFraction) {
        rounded.setHours(rounded.getHours() + 1, 0, 0, 0);
      } else {
        rounded.setSeconds(0, 0);
      }
      return rounded;
    };

    const addDays = (date, days) => {
      const next = new Date(date);
      next.setDate(next.getDate() + days);
      return next;
    };

    const addHours = (date, hours) => {
      const next = new Date(date);
      next.setHours(next.getHours() + hours);
      return next;
    };

    const syncDropoffFromPickup = () => {
      if (!pickupInput || !dropoffInput || !pickupInput.value) return;
      const pickupDate = new Date(pickupInput.value);
      if (Number.isNaN(pickupDate.getTime())) return;

      const minimumDropoff = addHours(pickupDate, 1);
      dropoffInput.min = toLocalInputValue(minimumDropoff);

      if (!dropoffInput.value) {
        dropoffInput.value = toLocalInputValue(addDays(pickupDate, 1));
        return;
      }

      const dropoffDate = new Date(dropoffInput.value);
      if (Number.isNaN(dropoffDate.getTime()) || dropoffDate <= pickupDate) {
        dropoffInput.value = toLocalInputValue(addDays(pickupDate, 1));
      }
    };

    const now = new Date();
    const defaultPickup = roundUpToNextHour(addHours(now, 2));
    const defaultDropoff = addDays(defaultPickup, 1);

    if (pickupInput) {
      pickupInput.min = toLocalInputValue(now);
      if (!pickupInput.value) {
        pickupInput.value = toLocalInputValue(defaultPickup);
      }
    }

    if (dropoffInput) {
      dropoffInput.min = toLocalInputValue(addHours(defaultPickup, 1));
      if (!dropoffInput.value) {
        dropoffInput.value = toLocalInputValue(defaultDropoff);
      }
    }

    syncDropoffFromPickup();
    pickupInput?.addEventListener("change", syncDropoffFromPickup);
    pickupInput?.addEventListener("input", syncDropoffFromPickup);

    const setError = (message) => {
      if (!errorEl) return;
      if (!message) {
        errorEl.classList.add("hidden");
        errorEl.textContent = "";
        return;
      }
      errorEl.textContent = message;
      errorEl.classList.remove("hidden");
    };

    form?.addEventListener("submit", (event) => {
      setError("");
      loadingEl?.classList.add("hidden");

      const location = locationInput?.value?.trim();
      const pickup = pickupInput?.value;
      const dropoff = dropoffInput?.value;

      if (!location || !pickup || !dropoff) {
        event.preventDefault();
        setError("Please fill location, pick-up date/time, and drop-off date/time.");
        return;
      }

      const pickupDate = new Date(pickup);
      const dropoffDate = new Date(dropoff);
      const nowDate = new Date();

      if (pickupDate < nowDate) {
        event.preventDefault();
        setError("Pick-up date/time cannot be in the past.");
        return;
      }

      if (dropoffDate <= pickupDate) {
        event.preventDefault();
        setError("Drop-off must be later than pick-up.");
        return;
      }

      loadingEl?.classList.remove("hidden");
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Searching...";
      }
    });
  </script>
</BaseLayout>
