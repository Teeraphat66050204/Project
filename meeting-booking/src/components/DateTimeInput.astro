---
type Props = {
  id: string;
  name: string;
  label: string;
  value?: string;
  required?: boolean;
  min?: string;
  class?: string;
};

const {
  id,
  name,
  label,
  value = "",
  required = false,
  min,
  class: className = "",
} = Astro.props;
---

<label for={id} class="form-label">
  <span>{label}</span>
  <input
    id={id}
    name={name}
    type="datetime-local"
    value={value}
    min={min}
    required={required}
    class:list={["form-field", className]}
  />
</label>
