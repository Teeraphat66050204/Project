---
type Option = { label: string; value: string };

type Props = {
  id: string;
  name: string;
  label: string;
  options: Option[];
  value?: string;
  required?: boolean;
  class?: string;
};

const {
  id,
  name,
  label,
  options,
  value = "",
  required = false,
  class: className = "",
} = Astro.props;
---

<label for={id} class="form-label">
  <span>{label}</span>
  <select id={id} name={name} required={required} class:list={["form-field", className]}>
    {options.map((option) => (
      <option value={option.value} selected={option.value === value}>
        {option.label}
      </option>
    ))}
  </select>
</label>
