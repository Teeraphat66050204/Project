---
type Props = {
  id: string;
  name: string;
  label: string;
  type?: "text" | "email" | "tel" | "password";
  value?: string;
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  class?: string;
};

const {
  id,
  name,
  label,
  type = "text",
  value = "",
  placeholder = "",
  required = false,
  autocomplete,
  class: className = "",
} = Astro.props;

const isPassword = type === "password";
---

<label for={id} class="form-label">
  <span>{label}</span>
  <div class="relative">
    <input
      id={id}
      name={name}
      type={type}
      value={value}
      placeholder={placeholder}
      required={required}
      autocomplete={autocomplete}
      class:list={["form-field", isPassword && "pr-11", className]}
    />
    {isPassword && (
      <button
        type="button"
        class="absolute right-2 top-1/2 -translate-y-1/2 rounded-lg border border-white/10 bg-[#111827] p-1.5 text-[rgba(249,250,251,0.75)] transition hover:border-[#F59E0B]/50 hover:text-[#F59E0B] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#F59E0B]/40"
        data-password-toggle
        data-target={id}
        aria-label="Show password"
        aria-pressed="false"
      >
        <svg data-eye-open xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        <svg data-eye-closed xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="hidden h-4 w-4 fill-none stroke-current" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 3l18 18"></path>
          <path d="M10.6 10.6a2 2 0 0 0 2.8 2.8"></path>
          <path d="M9.9 5.2A10.7 10.7 0 0 1 12 5c6.5 0 10 7 10 7a15 15 0 0 1-3.2 4.2"></path>
          <path d="M6.7 6.7C4.3 8.2 2.9 10.6 2 12c0 0 3.5 7 10 7 1.8 0 3.3-.5 4.6-1.2"></path>
        </svg>
      </button>
    )}
  </div>
</label>

<script>
  const toggles = Array.from(document.querySelectorAll("[data-password-toggle]"));
  for (const toggle of toggles) {
    if (toggle.dataset.bound === "true") continue;
    toggle.dataset.bound = "true";

    const inputId = toggle.getAttribute("data-target");
    const input = inputId ? document.getElementById(inputId) : null;
    const eyeOpen = toggle.querySelector("[data-eye-open]");
    const eyeClosed = toggle.querySelector("[data-eye-closed]");
    if (!input) continue;

    toggle.addEventListener("click", () => {
      const show = input.getAttribute("type") === "password";
      input.setAttribute("type", show ? "text" : "password");
      toggle.setAttribute("aria-pressed", show ? "true" : "false");
      toggle.setAttribute("aria-label", show ? "Hide password" : "Show password");
      eyeOpen?.classList.toggle("hidden", show);
      eyeClosed?.classList.toggle("hidden", !show);
    });
  }
</script>
